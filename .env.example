# ── Database ──────────────────────────────────────────────────────────────────
DUCKDB_PATH=data/processed/churn.db

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=mlruns
MLFLOW_EXPERIMENT_NAME=churn-prediction

# ── Data paths ────────────────────────────────────────────────────────────────
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
FEATURES_DATA_DIR=data/features
OUTPUTS_DIR=outputs

# ── Model config ─────────────────────────────────────────────────────────────
MODEL_REGISTRY_NAME=churn-lgbm
PREDICTION_WINDOW_DAYS=90
CHURN_THRESHOLD=0.5
HIGH_RISK_THRESHOLD=0.7
MEDIUM_RISK_THRESHOLD=0.3

# ── Monitoring ────────────────────────────────────────────────────────────────
PSI_ALERT_THRESHOLD=0.2
DRIFT_ALERT_WEBHOOK_URL=

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=info
